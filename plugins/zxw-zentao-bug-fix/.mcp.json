{
  "mcpServers": {
    "zentao": {
      "command": "npx",
      "args": [
        "-y",
        "zentao-mcp"
      ],
      "env": {
        "ZENTAO_BASE_URL": "http://your-zentao-host/zentao/",
        "ZENTAO_ACCOUNT": "your-account",
        "ZENTAO_PASSWORD": "your-password",
        "MCP_ENABLE_WRITE_TOOLS": "true"
      }
    }
  }
}
